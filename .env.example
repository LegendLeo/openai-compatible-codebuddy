# CodeBuddy Authentication
CODEBUDDY_API_KEY=your-api-key-here
# CODEBUDDY_INTERNET_ENVIRONMENT=internal  # 中国版用户取消注释
# CODEBUDDY_INTERNET_ENVIRONMENT=ioa       # iOA 版用户取消注释

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Default Model
DEFAULT_MODEL=gemini-3.0-pro
FALLBACK_MODEL=gemini-3.0-pro

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL_MS=300000       # 缓存过期时间，默认 5 分钟
CACHE_MAX_SIZE=100        # 最大缓存条目数

# Logging
LOG_LEVEL=info            # debug | info | warn | error
